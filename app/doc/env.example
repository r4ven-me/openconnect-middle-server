# System
TZ="Europe/Moscow"

# Certbot
# OC_USER_EMAIL="mail@example.com"

# OpenConnect server
OC_SRV_PORT="443"
OC_SRV_CN="example.com"
OC_SRV_CA="Example CA"
OC_IPV4_NET="10.10.10.0"
OC_IPV4_MASK="255.255.255.0"
OC_DNS1="8.8.8.8"
OC_DNS2="8.8.4.4"
OC_CAMOUFLAGE_ENABLE="false"
OC_CAMOUFLAGE_SECRET="secretword"
OC_CAMOUFLAGE_REALM="Welcome to admin panel"

# OTP
OC_OTP_ENABLE="false"
OC_OTP_SEND_BY_EMAIL="false"
# OC_OTP_MSMTP_HOST="smtp.example.com"
# OC_OTP_MSMTP_PORT="465"
# OC_OTP_MSMTP_USER="mail@example.com"
# OC_OTP_MSMTP_PASSWORD="SuPeRsEcReTpAsSwOrD"
# OC_OTP_MSMTP_FROM="mail@example.com"
OC_OTP_SEND_BY_TELEGRAM="false"
# OC_OTP_TG_TOKEN="1234567890:QWERTYuio-PA1DFGHJ2_KlzxcVBNmqWEr3t"

# OpenConnect client
# Optional: force physical uplink interface for NAT rules. Empty means auto-detect.
# OC_MAIN_IFACE="eth0"
OC_CLIENT_ENABLE="false"
OC_CLIENT_IFACE="tun10"
OC_CLIENT_CHECK_INTERVAL="5"
OC_CLIENT_CHECK_THRESHOLD="3"

# Number of configured OC_CLIENT_<index> profiles.
# Set to "2" when OC_CLIENT_1_* variables are enabled, "3" for OC_CLIENT_2_*, etc.
OC_CLIENT_COUNT="1"

# OC_CLIENT_0_SSL_FLAG=true
# OC_CLIENT_0_SERVER="ocserv1.example.com"
# OC_CLIENT_0_SERVER_PORT=443
# OC_CLIENT_0_CERT_FILE="/etc/openconnect/ocserv1.p12"
# OC_CLIENT_0_CERT_PASS="p12SecretInBase64encode" 
# OC_CLIENT_0_CHECK_HOST="10.120.120.1"

# OC_CLIENT_1_SSL_FLAG=false
# OC_CLIENT_1_SERVER="ocserv2.example.com"
# OC_CLIENT_1_SERVER_PORT="443/?SecretUrl"
# OC_CLIENT_1_CERT_FILE="/etc/openconnect/ocserv2.p12"
# OC_CLIENT_1_CERT_PASS="p12SecretInBase64encode"
# OC_CLIENT_1_CHECK_HOST="10.130.130.1"

# Dnsmasq
OC_SPLIT_ENABLE="false"
OC_SPLIT_TUNNEL_DNS="false"
# OC_SPLIT_ROUTES='
# 123.234.123.234/24
# 123.234.123.234/16
# 123.234.123.234/8
# '
# OC_SPLIT_DOMAINS='
# ifconfig.me
# google.com
# google.ru
# '
